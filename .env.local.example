# Copy to .env.local and fill in. Do not commit .env.local.

# Supabase — Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public app URL — production domain
NEXT_PUBLIC_APP_URL=https://review.baamplatform.com

# Local dev URL (the port the Next.js dev server binds to — see package.json dev script)
NEXT_PUBLIC_SITE_URL=http://localhost:4001

# Google Business Profile OAuth (Session 3)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic — review drafts (Session 6) and /api/send/rewrite-body
# (Session 7+). Haiku 4.5 by default.
ANTHROPIC_API_KEY=
# Optional override for the model used by the "Rewrite with AI" button on
# /app/send. Defaults to claude-haiku-4-5-20251001 if unset.
AI_REWRITE_CLAUDE_MODEL=

# Resend — email send (Session 7). RESEND_FROM must be on a verified sender domain.
RESEND_API_KEY=
RESEND_FROM=No-Reply<no-reply@baamplatform.com>
# Optional but recommended in production: signing secret from Resend dashboard
# → Webhooks → your endpoint. Format: "whsec_…". When set, /api/webhooks/resend
# verifies the svix-signature header and rejects forged requests.
RESEND_WEBHOOK_SECRET=

# Twilio — SMS send (Session 7). Optional until A2P 10DLC registration completes.
# TWILIO_FROM_NUMBER must be in E.164 (+15551234567).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
